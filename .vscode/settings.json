{
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file", // tell oxfmt to format the whole file, not only the modified lines
    "files.exclude": {
        "**/.git": true,
        /*
         * See
         * https://stackoverflow.com/questions/47405315/visual-studio-code-and-subfolder-specific-settings/50305853#50305853
         */
        "clients": true,
        "server": true,
        "docs": true
    }
}
