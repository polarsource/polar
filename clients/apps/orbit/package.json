{
  "name": "orbit-playground",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3333",
    "build": "next build --turbopack",
    "start": "next start -p 3333",
    "gen:props": "node scripts/extract-props.mjs",
    "format": "oxfmt ./src",
    "format:check": "oxfmt --check ./src",
    "lint:only": "eslint --max-warnings 0 .",
    "lint": "pnpm format:check && pnpm lint:only",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "=24"
  },
  "dependencies": {
    "@polar-sh/orbit": "workspace:*",
    "@polar-sh/ui": "workspace:*",
    "@stylexjs/stylex": "^0.18.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@polar-sh/eslint-config": "workspace:*",
    "@polar-sh/typescript-config": "workspace:*",
    "@stylexjs/babel-plugin": "^0.18.2",
    "@stylexjs/postcss-plugin": "^0.18.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.4",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^25.0.1",
    "typescript": "5.9.3"
  }
}
