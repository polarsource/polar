{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-aup": "cp \"src/app/(main)/(website)/(landing)/(mdx)/legal/acceptable-use-policy/page.mdx\" \"src/app/(main)/onboarding/validate-description/acceptable-use-policy.mdx\"",
    "prebuild": "pnpm copy-aup",
    "dev": "pnpm copy-aup && next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "format": "oxfmt ./src",
    "format:check": "oxfmt --check ./src",
    "lint:only": "eslint --max-warnings 0 .",
    "lint": "pnpm format:check && pnpm lint:only",
    "lint:changed": "eslint --max-warnings 0 $(git diff --name-only --relative --diff-filter=ACMR HEAD | grep -E '\\.(js|jsx|ts|tsx)$')",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "=24"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.70",
