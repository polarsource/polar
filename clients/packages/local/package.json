{
  "name": "@polar-sh/local",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first, billing-as-code usage metering for Polar — deterministic, replayable, versioned. Durably buffers event ingestion, forwards to the Polar API fault-tolerantly, and reconciles.",
  "author": "Polar",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/polarsource/polar.git",
    "directory": "clients/packages/local"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "bin": {
    "polar-local": "./bin/polar-local.mjs"
  },
  "files": [
    "src",
    "bin",
    "README.md"
  ],
  "scripts": {
    "start": "NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx src/main.ts",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "test:watch": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -f Dockerfile -t polar-local ../..",
    "docker:run": "docker run --rm -p 8787:8787 -v polar-local-data:/data --env-file .env polar-local"
  },
  "dependencies": {
    "@polar-sh/client": "workspace:*",
    "effect": "^3.12.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
