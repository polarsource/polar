{
  "$schema": "https://v2-9-4.turborepo.dev/schema.json",
  "globalEnv": [
    "POLAR_API_URL",
    "EXPO_PUBLIC_POLAR_SERVER_URL",
    "NODE_ENV",
    "NEXT_PHASE",
    "NEXT_RUNTIME",
    "NEXT_PUBLIC_ENVIRONMENT",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_BACKOFFICE_URL",
    "NEXT_PUBLIC_STRIPE_KEY",
    "NEXT_PUBLIC_FRONTEND_BASE_URL",
    "POLAR_PREVIEW_ACCESS_TOKEN",
    "POLAR_PREVIEW_BUILD",
    "POLAR_PREVIEW_BACKEND_HOST",
    "VERCEL_ENV",
    "NEXT_PUBLIC_VERCEL_ENV",
    "NEXT_PUBLIC_LOGIN_PATH",
    "NEXT_PUBLIC_GITHUB_APP_NAMESPACE",
    "NEXT_PUBLIC_GITHUB_BADGE_EMBED_DEFAULT_LABEL",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_POSTHOG_TOKEN",
    "NEXT_PUBLIC_STRIPE_COUNTRIES_WHITELIST",
    "NEXT_PUBLIC_APPLE_DOMAIN_ASSOCIATION",
    "SENTRY_AUTH_TOKEN",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_PROJECT",
    "SENTRY_ORG",
    "POLAR_AUTH_COOKIE_KEY",
    "POLAR_AUTH_MCP_COOKIE_KEY",
    "POLAR_CHECKOUT_EMBED_SCRIPT_ALLOWED_ORIGINS",
    "NEXT_PUBLIC_CHECKOUT_EMBED_SCRIPT_SRC",
    "S3_PUBLIC_IMAGES_BUCKET_PROTOCOL",
    "S3_PUBLIC_IMAGES_BUCKET_HOSTNAME",
    "S3_PUBLIC_IMAGES_BUCKET_PORT",
    "S3_PUBLIC_IMAGES_BUCKET_PATHNAME",
    "S3_UPLOAD_ORIGINS",
    "PYDANTIC_AI_GATEWAY_API_KEY",
    "GRAM_API_KEY",
    "GRAM_API_URL",
    "MCP_OAUTH2_CLIENT_ID",
    "MCP_OAUTH2_CLIENT_SECRET",
    "MINTLIFY_ASSISTANT_API_KEY",
    "ATTIO_API_KEY",
    "ATTIO_STARTUP_LIST_ID",
    "CI"
  ],
  "tasks": {
    "test": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
