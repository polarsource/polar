{
  "name": "@polar-sh/sdk",
  "version": "{{ version }}",
  "description": "Polar SDK — A billing platform for the intelligence era",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist", "README.md"
  ],
  "engines": { "node": ">=18" },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
{% for version in ir.versions %}
    ,
    "./{{version.version}}": {
      "import": { "types": "./dist/{{version.version}}/index.d.mts", "default": "./dist/{{version.version}}/index.mjs" },
      "require": { "types": "./dist/{{version.version}}/index.d.cts", "default": "./dist/{{version.version}}/index.cjs" }
    }
{% endfor %}
  },
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "polar",
    "sdk",
    "api",
    "typescript"
  ],
  "author": "Polar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/polar-sh/polar",
    "directory": "sdk/typescript"
  }
}
