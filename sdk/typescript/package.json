{
  "name": "@polar-sh/sdk",
  "version": "1.0.0-alpha.3",
  "description": "Polar SDK — A billing platform for the intelligence era",
  "keywords": [
    "api",
    "polar",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "author": "Polar",
  "repository": {
    "type": "git",
    "url": "https://github.com/polar-sh/polar",
    "directory": "sdk/typescript"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./2026-04": {
      "import": {
        "types": "./dist/2026-04/index.d.mts",
        "default": "./dist/2026-04/index.mjs"
      },
      "require": {
        "types": "./dist/2026-04/index.d.cts",
        "default": "./dist/2026-04/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
